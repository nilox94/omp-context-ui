{
	"name": "omp-context-ui",
	"version": "0.1.0",
	"description": "Interactive context window inspector for oh-my-pi",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/nilox94/omp-context-ui",
	"engines": {
		"bun": ">=1.3.14"
	},
	"imports": {
		"@/*": "./src/*"
	},
	"omp": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fmt": "biome format --write .",
		"fix": "biome check --write --unsafe .",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": ">=16.0.0 <17.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@oh-my-pi/pi-coding-agent": "16.0.3",
		"@oh-my-pi/pi-tui": "16.0.3",
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "7.0.0-dev.20260618.1"
	},
	"overrides": {
		"@opentelemetry/core": "2.8.0",
		"@opentelemetry/resources": "2.8.0",
		"@opentelemetry/sdk-trace-base": "2.8.0",
		"@opentelemetry/sdk-metrics": "2.8.0",
		"esbuild": "0.28.1"
	}
}
