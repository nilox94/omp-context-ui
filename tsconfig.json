{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		},
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"types": ["bun-types"]
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
